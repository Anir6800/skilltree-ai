# ──────────────────────────────────────────────────────────────────────────
# Contact mail microservice (backend/mail-server.js)
# ──────────────────────────────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_TO_EMAIL=
MAIL_SERVER_PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
MAIL_SERVICE_URL=http://127.0.0.1:4000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Django core (backend) — previously undocumented; required for the app + ETL
# ──────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
REDIS_URL=redis://localhost:6379/0

# JWT (shared by SimpleJWT today and mongo/auth.py after cutover)
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# LM Studio / ChromaDB (unchanged by the Mongo migration)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=openai/gpt-oss-20b
CHROMA_PATH=./chroma_db

# ──────────────────────────────────────────────────────────────────────────
# SOURCE relational DB — keep set during migration so the ETL can READ it.
# Remove ONLY after a verified MongoDB cutover (see mongodb_migration_report.md).
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/skilltree
# (Dev default if unset is sqlite:///db.sqlite3)

# ──────────────────────────────────────────────────────────────────────────
# TARGET MongoDB (new) — used by mongo/connection.py, ETL, and the app post-cutover
# ──────────────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=skilltree_ai
MONGODB_TIMEOUT_MS=5000

# Cutover flag — when True, app bootstraps the MongoEngine connection.
# Leave False until views/serializers are ported and data is verified.
USE_MONGODB=False
